# Copy to .env and fill in. Do NOT commit .env.

# LiveKit (from your LiveKit Cloud or self-hosted project)
LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sarvam (dashboard.sarvam.ai → API keys)
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx

# Twilio creds are configured in the LiveKit SIP trunk, not used directly by this agent.
# See README → "Twilio wiring".
