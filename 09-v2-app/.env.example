# Payments (Phase 3 ★)
PAYMENT_LINK_SECRET=replace-with-long-random-string   # HMAC for link signatures
PAYMENT_WEBHOOK_SECRET=replace-with-pg-shared-secret  # HMAC key your PG signs webhooks with
BANK_VPA=skvcb@upi
BANK_NAME=SKVCB
APP_URL=http://localhost:3000

# Compliance
# When "true", recorded voice consent overrides the DND registry for account-servicing
# contact (transactional). Confirm with compliance counsel before enabling in production.
DND_CONSENT_OVERRIDE=true

# Dev-only: role assumed when no x-role header is sent (officer | compliance | admin)
DEFAULT_ROLE=officer

# ---- Enterprise hardening (Phase 6) ----
# AUTH_MODE=session enforces cookie login only (disables the x-role dev fallback)
AUTH_MODE=header
SESSION_SECRET=replace-with-long-random-string
# Default user passwords, seeded on first run (users: officer1 / compliance1 / admin)
DEFAULT_OFFICER_PASSWORD=ChangeMe123!
DEFAULT_COMPLIANCE_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
# When set, the dev store is persisted as AES-256-GCM ciphertext (data/db.json.enc)
#STORE_ENCRYPTION_KEY=replace-with-long-random-string
RATE_LIMIT_PER_MIN=300
# CBS delta sync endpoint (vendor adapter reads this; see src/lib/cbs.ts)
#CBS_API_URL=https://cbs.bank.coop/api/v1

# ---- PostgreSQL (production data layer) ----
# prisma db push && npx tsx prisma/seed.ts loads the CBS export (all 12 tables verified)
#DATABASE_URL=postgresql://sahayak:password@localhost:5432/sahayak

# ---- Twilio (real telephony; unset = simulated dispatch) ----
# Setting all three makes /api/outreach + campaigns place REAL PSTN calls.
#TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#TWILIO_AUTH_TOKEN=your-auth-token
#TWILIO_FROM_NUMBER=+1xxxxxxxxxx
# Sarvam TTS key — used by scripts/generate-call-audio.mjs (agent "Asha", voice anushka)
#SARVAM_API_KEY=sk_...
# Personalized per-loan call audio (name + EMI + days overdue + pending, daypart greeting).
# Generate: SARVAM_API_KEY=... node scripts/generate-call-audio.mjs <loanId...>
# Then serve public/audio from here (public repo raw URL, or your APP_URL/audio in prod).
# placeCall picks call-<loanId>-<morning|afternoon|evening>.wav by IST daypart.
#AUDIO_BASE_URL=https://raw.githubusercontent.com/<owner>/<repo>/main/09-v2-app/public/audio
# Fallback generic greeting if no per-loan audio exists (else 2s pause + hangup)
#GREETING_AUDIO_URL=https://your-host/greeting-asha-mr.wav
# ---- Turn-by-turn conversation (Twilio <Gather> loop → Sarvam LLM + TTS) ----
# Set CONVERSATION_MODE=1 AND a PUBLIC https APP_URL, and calls become a real back-and-forth
# (borrower speaks → Asha replies → … → PTP + payment link). Needs SARVAM_API_KEY.
# APP_URL must be reachable by Twilio: deploy, or tunnel (e.g. cloudflared tunnel --url http://localhost:3000).
#CONVERSATION_MODE=1
# Folder-06 media-stream bridge for the lowest-latency two-way leg (barge-in, streaming ASR).
# When set, this WINS over both the Gather conversation and the pre-recorded audio.
#MEDIA_STREAM_WSS=wss://your-host/stream
# PILOT SAFETY: with a real trunk, only these E.164 numbers may be dialed/messaged
# (comma-separated). Set to your own verified number(s); clear only at production go-live.
#OUTBOUND_CALL_ALLOWLIST=+91xxxxxxxxxx
# Twilio WhatsApp sender (sandbox: +14155238886 — recipients must join the sandbox first)
#TWILIO_WHATSAPP_FROM=+14155238886
# Map tester-owned numbers onto seeded borrowers for live tests (applied at seed time)
#SEED_PHONE_OVERRIDES=HL-2022-33490:+91xxxxxxxxxx,TWL-2024-88412:+91yyyyyyyyyy
